# SQL Server connection for Props DB (projections, NBA stats, PrizePicks, Underdog, etc.)
# Copy this file to .env in the same directory (repo root) and set your values.
# All scripts (FastAPI app, underdog_scraper, prizepicks_scraper, nba_scraper, etc.) load .env automatically.

# Option A: Windows Authentication (no user/password)
PROPS_DB_USE_TRUSTED_CONNECTION=1

# Option B: SQL user/password (use same credentials as NBA stats / PrizePicks)
# PROPS_DB_USER=your_sql_username
# PROPS_DB_PASSWORD=your_sql_password

# Optional (defaults shown)
# PROPS_DB_SERVER=localhost\SQLEXPRESS
# PROPS_DATABASE=Props
